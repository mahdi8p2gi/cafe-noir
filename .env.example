# ===========================
# Database
# ===========================
# SQLite (development)
DATABASE_URL="file:./db/custom.db"

# PostgreSQL (production example)
# DATABASE_URL="postgresql://user:password@localhost:5432/cafe_noir?schema=public"

# ===========================
# NextAuth.js
# ===========================
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="cafenoir-dev-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ===========================
# Z.ai SDK (optional - for AI image generation)
# ===========================
# Get your API key from https://z.ai
# ZAI_API_KEY="your-zai-api-key-here"

# ===========================
# SMTP (optional - for email verification & password reset)
# ===========================
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
# SMTP_FROM="Café Noir <noreply@cafenoir.ir>"

# ===========================
# Payment Gateway (optional - for online payments)
# ===========================
# PAYMENT_GATEWAY="zarinpal"
# PAYMENT_MERCHANT_ID="your-merchant-id"
# PAYMENT_CALLBACK_URL="http://localhost:3000/api/payment/callback"
