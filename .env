# Database — PostgreSQL (required for Vercel deployment)
# For local dev, use a PostgreSQL database (local or cloud like Neon)
# Example: postgresql://user:password@host:5432/dbname?schema=public
DATABASE_URL="postgresql://placeholder:placeholder@localhost:5432/cafenoir?schema=public"

# NextAuth
NEXTAUTH_SECRET="cafenoir-dev-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
